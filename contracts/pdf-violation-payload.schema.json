{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PdfViolationPayload",
  "type": "object",
  "properties": {
    "scanMetadata": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "filename": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "documentHash": { "type": "string" },
        "pageCount": { "type": "integer", "minimum": 1 }
      },
      "required": ["source", "timestamp", "documentHash", "pageCount"]
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ruleId": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["minor", "moderate", "serious", "critical"]
          },
          "description": { "type": "string" },
          "pdfUaReference": { "type": "string" },
          "wcagReference": { "type": "string" },
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "page": { "type": "integer", "minimum": 1 },
                "objectRef": { "type": "string" },
                "evidence": { "type": "string" },
                "ocrDerived": { "type": "boolean" },
                "ocrConfidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "required": ["page", "evidence", "ocrDerived"]
            }
          }
        },
        "required": ["ruleId", "severity", "description", "locations"]
      }
    }
  },
  "required": ["scanMetadata", "violations"]
}

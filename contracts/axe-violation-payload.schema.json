{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AxeViolationPayload",
  "type": "object",
  "properties": {
    "scanMetadata": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "timestamp": { "type": "string", "format": "date-time" },
        "viewport": { "type": "string", "example": "1920x1080" }
      },
      "required": ["url", "timestamp"]
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ruleId": { "type": "string", "example": "image-alt" },
          "impact": {
            "type": "string",
            "enum": ["minor", "moderate", "serious", "critical"]
          },
          "description": { "type": "string" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "targetSelector": {
                  "type": "string",
                  "example": "#main-header > img.logo"
                },
                "rawHtml": {
                  "type": "string",
                  "example": "<img src='/logo.png' class='logo'>"
                },
                "failureSummary": {
                  "type": "string",
                  "example": "Fix any of the following: Element does not have an alt attribute."
                },
                "elementScreenshotBase64": {
                  "type": "string",
                  "description": "Base64 encoded PNG of the specific failing DOM node"
                },
                "warning": {
                  "type": "string",
                  "description": "Optional warning when screenshot or extraction is partial"
                }
              },
              "required": ["targetSelector", "rawHtml", "failureSummary"]
            }
          }
        },
        "required": ["ruleId", "impact", "description", "nodes"]
      }
    }
  },
  "required": ["scanMetadata", "violations"]
}
